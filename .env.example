# Database
# schema.prisma is currently set to provider = "mysql" (cPanel deployment).
# Get these values from cPanel → MySQL Databases after creating the DB + user:
DATABASE_URL="mysql://cpaneluser_dbuser:YOUR_DB_PASSWORD@localhost:3306/cpaneluser_norishe"

# If you're developing locally instead and want SQLite, change provider back
# to "sqlite" in prisma/schema.prisma and use:
# DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-random-32-byte-string"

# Seed admin account (used once by `npm run seed`)
SEED_ADMIN_EMAIL="admin@norishe.vip"
SEED_ADMIN_PASSWORD="Norishe#Admin2026"

# Email (optional — leave blank to log to console instead)
RESEND_API_KEY=""
# or SMTP
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Norishé <hello@norishe.vip>"
ADMIN_NOTIFICATION_EMAIL="hello@norishe.vip"

# Payments (Paystack) — leave blank to fall back to bank-transfer/on-delivery flow
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=""
PAYSTACK_SECRET_KEY=""

# Analytics (optional, first-party logging always on; these add third-party pixels)
NEXT_PUBLIC_GA4_ID=""
NEXT_PUBLIC_META_PIXEL_ID=""

# Site
NEXT_PUBLIC_SITE_URL="https://norishe.vip"
